# =============================================================================
# CYMRU Agent Configuration Template
# Copy this file to .env and fill in your API keys
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration (Project: rooffhgbxafyjcwmwpsy)
# -----------------------------------------------------------------------------
SUPABASE_URL="https://rooffhgbxafyjcwmwpsy.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# -----------------------------------------------------------------------------
# Inference / LLM Providers
# -----------------------------------------------------------------------------
# Gemini is the default provider for CYMRU. Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Required for generating pgvector embeddings using text-embedding-3-small)
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter (Optional backup)
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# -----------------------------------------------------------------------------
# Messaging Gateways
# -----------------------------------------------------------------------------
# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# WhatsApp Configuration
WHATSAPP_API_KEY=your_whatsapp_api_key_here

# PTT / Radio Bridge authentication key
CYMRU_RADIO_BRIDGE_KEY=your_radio_bridge_key_here

# -----------------------------------------------------------------------------
# System settings
# -----------------------------------------------------------------------------
HERMES_UID=10000
HERMES_GID=10000
